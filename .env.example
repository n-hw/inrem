# Project
PROJECT_NAME=InRem
PROJECT_VERSION=0.1.0
ENV=development

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inrem
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend
API_V1_STR=/api/v1
SECRET_KEY=secret
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Observability
LOG_LEVEL=INFO
# SENTRY_DSN=  # 출시 시 https://sentry.io DSN 입력 (비워두면 Sentry 비활성)

# Email — Gmail SMTP (dev/alpha 단계)
# 1) Google 계정 → 보안 → 2단계 인증 ON
# 2) 같은 페이지 "앱 비밀번호" 생성 (앱: "메일", 기기: "기타" → "InRem")
# 3) 생성된 16자리(공백 제거)를 GMAIL_APP_PASSWORD 에 입력
# 비워두면 자동으로 MockEmailProvider 로 폴백 (개발 안전).
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=InRem